# 复制本文件为 .env：
#   cp .env.example .env
# 然后按需填写下面的环境变量。

# ========== LLM（任何 OpenAI API 兼容服务都可） ==========
# OpenAI / Azure OpenAI / Ollama(via openai-compatible) / vLLM 等
OPENAI_API_KEY=

# 例如（OpenAI 官方）：https://api.openai.com/v1
# 如果你的服务已经包含 /v1，也可以直接填到这里（以你的服务为准）
OPENAI_BASE_URL=https://api.openai.com/v1

# 例如：gpt-4o-mini / gpt-4.1-mini / 你的私有模型 ID
OPENAI_MODEL_ID=

# ========== 联网搜索（可选，但不配就无法推荐景点） ==========
TAVILY_API_KEY=

# ========== Agent 默认城市（可选） ==========
AGENT_DEFAULT_CITY=北京
